{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "win-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "win-debug",
      "displayName": "Windows Debug",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_WARNINGS_AS_ERRORS": "OFF",
        "ENABLE_HARDENING": "ON",
        "ENABLE_SANITIZERS": "ON",
        "ENABLE_STATIC_ANALYZERS": "ON"
      }
    },
    {
      "name": "win-release",
      "displayName": "Windows Release",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_IPO": "ON",
        "ENABLE_HARDENING": "ON",
        "ENABLE_WARNINGS_AS_ERRORS": "ON",
        "ENABLE_STATIC_ANALYZERS": "OFF"
      }
    },
    {
      "name": "win-relwithdebinfo",
      "displayName": "Windows RelWithDebInfo",
      "inherits": "win-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "ENABLE_IPO": "ON",
        "ENABLE_HARDENING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win-debug",
      "configurePreset": "win-debug",
      "configuration": "Debug",
      "jobs": 16
    },
    {
      "name": "win-release",
      "configurePreset": "win-release",
      "configuration": "Release",
      "jobs": 16
    },
    {
      "name": "win-relwithdebinfo",
      "configurePreset": "win-relwithdebinfo",
      "configuration": "RelWithDebInfo",
      "jobs": 16
    }
  ]
}